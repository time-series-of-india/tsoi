# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Build-time database (TimescaleDB, infra/docker-compose) ---
DB_PASSWORD=change-me
# Which PostgreSQL schema the ETL writes to (default economy_dev; prod: economy)
#SCHEMA_NAME=economy_dev

# --- Cloudflare deploy (scripts/deploy.sh / publish.sh → wrangler) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Cloudflare Web Analytics (optional) ---
# Cookieless page-view beacon. Create the site under Analytics & Logs →
# Web Analytics in the Cloudflare dashboard and paste its token here; the
# beacon is only injected at build time when this is set.
CF_BEACON_TOKEN=

# --- Local Grafana (dev-only exploration stack; not used by the site build) ---
GRAFANA_ADMIN_PASSWORD=
GF_AUTH_GOOGLE_CLIENT_ID=
GF_AUTH_GOOGLE_CLIENT_SECRET=
GRAFANA_RENDERER_TOKEN=
