---
// Per-deck route (/economy/play/payments). Decks are retired from the rack
// but their URLs live forever — old /economy/beats* shares 301 here
// (public/_redirects), so the page keeps rendering, unlisted (the short-read
// treatment). Games own the rack now.
import BeatsDeck from '../../../components/story/BeatsDeck.astro';
import { BEAT_DECKS } from '../../../lib/beats';

export function getStaticPaths() {
  return Object.keys(BEAT_DECKS).map((deck) => ({ params: { deck } }));
}

const deck = BEAT_DECKS[Astro.params.deck!];
---

<BeatsDeck deck={deck} />
