---
// Economy theme — the Reads index. A prominent flagship banner (chart thumbnail
// + deck) sits on top; every short read then follows in ONE uniform thumbnail
// grid — no rail/grid split. Thumbnails are chart-only captures generated by
// scripts/build-read-thumbs.mjs into public/thumbs/reads/<slug>.png.
// A Beats ⇄ Reads ⇄ Dashboards toggle (shared component) mirrors the other list
// views. Read pages live at /economy/reads/{slug} (registry: src/lib/reads-index.ts).
import StoryPage from '../../layouts/StoryPage.astro';
import SectionHeader from '../../components/editorial/SectionHeader.astro';
import ViewToggle from '../../components/editorial/ViewToggle.astro';
import { READS } from '../../lib/reads-index';
import { readingMinutes } from '../../lib/reading-time';
import { dataThrough } from '../../lib/data-through';

const sectionDate = new Date()
  .toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })
  .toUpperCase();

const [flagship, ...rest] = READS;
const thumb = (slug: string) => `/thumbs/reads/${slug}.png`;
const thumbDark = (slug: string) => `/thumbs/reads/${slug}-dark.png`;
---

<StoryPage
  title="Economy — Time Series of India"
  description="Reads on how money moves in India — UPI, NEFT, RTGS, cards, settlement systems, banks and states — charted from official RBI and NPCI releases."
>
  <ViewToggle active="reads" />

  <SectionHeader label="Economy" date={sectionDate} />
  <p class="intro">
    Reads on how India moves money, each charted from official RBI and NPCI data. Start with the
    longread on the machinery behind a single UPI tap, then browse the short reads &mdash; every one
    links to its full interactive dashboard.
  </p>

  <!-- ── flagship banner ─────────────────────────────────────────────── -->
  <a class="featured" href={`/economy/reads/${flagship.slug}`}>
    <span class="cover">
      <img class="t-light" src={thumb(flagship.slug)} alt="" loading="eager" />
      <img class="t-dark" src={thumbDark(flagship.slug)} alt="" loading="eager" />
    </span>
    <span class="f-body">
      <span class="tag">Featured &middot; Longread &middot; {readingMinutes(flagship.slug)} min read{dataThrough(flagship.slug) ? ` · data through ${dataThrough(flagship.slug)}` : ''}</span>
      <h2 class="f-title">{flagship.title}</h2>
      <span class="f-deck">{flagship.deck}</span>
      <span class="f-cta">Read the longread <span aria-hidden="true">&rarr;</span></span>
    </span>
  </a>

  <!-- ── all short reads, one uniform grid ───────────────────────────── -->
  <p class="list-label">More reads</p>
  <div class="read-grid">
    {
      rest.map((r) => (
        <a class="card" href={`/economy/reads/${r.slug}`}>
          <span class="card-cover">
            <img class="t-light" src={thumb(r.slug)} alt="" loading="lazy" />
            <img class="t-dark" src={thumbDark(r.slug)} alt="" loading="lazy" />
          </span>
          <span class="card-body">
            <span class="card-title">{r.title}</span>
            <span class="card-deck">{r.deck}</span>
            <span class="source">{r.source} &middot; {readingMinutes(r.slug)} min read{dataThrough(r.slug) ? ` · data through ${dataThrough(r.slug)}` : ''}</span>
          </span>
        </a>
      ))
    }
  </div>
</StoryPage>

<style>
  .intro {
    max-width: 70ch;
    margin: calc(var(--tsoi-spacing-unit) * 2) 0 0;
    font: var(--tsoi-text-deck);
    letter-spacing: var(--tsoi-text-deck-tracking);
    color: var(--tsoi-color-on-surface-variant);
  }

  /* ── flagship banner: chart thumbnail left, text right ─────────────── */
  .featured {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    margin-top: calc(var(--tsoi-spacing-unit) * 4);
    border-left: 4px solid var(--tsoi-color-primary);
    background: var(--tsoi-color-surface-container-low);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .featured:hover { background: var(--tsoi-color-surface-container-high); }
  /* the flagship cover is the portrait "five moments" strip; contain it on the
     matching surface so it blends, rather than cover-cropping a tall image. */
  .featured .cover {
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    padding: calc(var(--tsoi-spacing-unit) * 3) 0;
    background: var(--tsoi-color-surface-container-low);
    border-right: var(--tsoi-rule-column) solid var(--tsoi-color-outline);
  }
  .featured .cover img {
    width: auto; max-width: 100%; height: 100%; max-height: 360px;
    object-fit: contain; display: block;
  }

  /* theme-swapped thumbnails: light captures by default, dark captures under
     [data-theme='dark']. Both ship; CSS picks one. Selectors carry the same
     parent chain as the base img rules so they win on specificity. */
  .featured .cover .t-dark,
  .card-cover .t-dark { display: none; }
  :global(html[data-theme='dark']) .featured .cover .t-light,
  :global(html[data-theme='dark']) .card-cover .t-light { display: none; }
  :global(html[data-theme='dark']) .featured .cover .t-dark,
  :global(html[data-theme='dark']) .card-cover .t-dark { display: block; }
  .f-body {
    display: flex; flex-direction: column; justify-content: center;
    padding: calc(var(--tsoi-spacing-unit) * 3) calc(var(--tsoi-spacing-unit) * 3.5);
  }
  .tag {
    font: var(--tsoi-text-byline); letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--tsoi-color-primary);
  }
  .f-title {
    margin: var(--tsoi-spacing-unit) 0 0;
    font: var(--tsoi-text-headline-lg);
    letter-spacing: var(--tsoi-text-headline-lg-tracking);
  }
  .featured:hover .f-title { color: var(--tsoi-color-primary); }
  .f-deck {
    max-width: 52ch;
    margin: calc(var(--tsoi-spacing-unit) * 1.25) 0 0;
    font: var(--tsoi-text-body);
    color: var(--tsoi-color-on-surface-variant);
  }
  .f-cta {
    margin: calc(var(--tsoi-spacing-unit) * 2) 0 0;
    font: var(--tsoi-text-byline); letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--tsoi-color-primary);
  }
  .f-cta span { display: inline-block; transition: transform 0.15s; }
  .featured:hover .f-cta span { transform: translateX(3px); }

  /* ── short-read grid ───────────────────────────────────────────────── */
  .list-label {
    margin: calc(var(--tsoi-spacing-unit) * 5) 0 var(--tsoi-spacing-unit);
    font: var(--tsoi-text-byline); letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--tsoi-color-on-surface-variant);
  }
  .read-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: calc(var(--tsoi-spacing-unit) * 4) calc(var(--tsoi-spacing-unit) * 3);
  }
  .card { display: block; text-decoration: none; color: inherit; }
  .card-cover {
    display: block; aspect-ratio: 16 / 9; overflow: hidden;
    background: var(--tsoi-color-surface-container-low);
    border: 1px solid var(--tsoi-color-outline);
    transition: border-color 0.15s;
  }
  .card-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card:hover .card-cover { border-color: var(--tsoi-color-primary); }
  .card-body { display: block; padding-top: calc(var(--tsoi-spacing-unit) * 1.5); }
  .card-title {
    display: block;
    font: var(--tsoi-text-headline-md);
    letter-spacing: var(--tsoi-text-headline-md-tracking);
    line-height: 1.2;
  }
  .card:hover .card-title { color: var(--tsoi-color-primary); }
  .card-deck {
    display: block;
    margin: var(--tsoi-spacing-unit) 0 0;
    font: var(--tsoi-text-body);
    letter-spacing: var(--tsoi-text-body-tracking);
    color: var(--tsoi-color-on-surface-variant);
  }
  .source {
    display: block;
    margin-top: calc(var(--tsoi-spacing-unit) * 1.25);
    font: var(--tsoi-text-byline); letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--tsoi-color-on-surface-variant);
  }

  /* ── responsive ────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .read-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .featured { grid-template-columns: 1fr; margin-top: calc(var(--tsoi-spacing-unit) * 3); }
    .featured .cover {
      border-right: none;
      border-bottom: var(--tsoi-rule-column) solid var(--tsoi-color-outline);
      padding: calc(var(--tsoi-spacing-unit) * 3) 0 calc(var(--tsoi-spacing-unit) * 2);
    }
    .featured .cover img { max-height: 320px; }
    .f-body { padding: calc(var(--tsoi-spacing-unit) * 2.5) calc(var(--tsoi-spacing-unit) * 2.5)
      calc(var(--tsoi-spacing-unit) * 3); }
    /* grid → single column, thumbnail beside title (compact list feel) */
    .read-grid { grid-template-columns: 1fr; gap: 0; }
    .card {
      display: grid; grid-template-columns: 132px 1fr;
      column-gap: calc(var(--tsoi-spacing-unit) * 2);
      align-items: center;
      padding: calc(var(--tsoi-spacing-unit) * 2) 0;
    }
    .card + .card { border-top: var(--tsoi-rule-column) solid var(--tsoi-color-outline); }
    .card-body { padding-top: 0; }
    .card-deck { display: none; }
  }
</style>
