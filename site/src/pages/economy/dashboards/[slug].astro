---
// Spec-driven dashboard page: /economy/dashboards/{slug}.
// Enriches the spec at build time — fills select-control options (and resolves
// the '@latest' default) from the tidy dataset on disk — then hands the
// enriched spec to the generic DashboardView renderer.
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { resolve as pathResolve, dirname } from 'node:path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Masthead from '../../../components/layout/Masthead.astro';
import SectionNav from '../../../components/layout/SectionNav.astro';
import Footer from '../../../components/layout/Footer.astro';
import DashboardView from '../../../components/dashboard/DashboardView.astro';
import ShareButtons from '../../../components/editorial/ShareButtons.astro';
import { DASHBOARDS, getSpec } from '../../../lib/dashboards/specs';

export function getStaticPaths() {
  return DASHBOARDS.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const base = getSpec(slug!)!;

// Deep clone so we can enrich without mutating the shared spec object.
const spec = structuredClone(base);

// Read the tidy dataset from public/ at build time to populate select options.
const PUBLIC = pathResolve(dirname(fileURLToPath(import.meta.url)), '../../../../public');
const { rows } = JSON.parse(readFileSync(pathResolve(PUBLIC, '.' + spec.dataset), 'utf8'));

const distinct = (field: string): string[] => [...new Set<string>(rows.map((r: any) => String(r[field])))];

for (const c of spec.globals ?? []) {
  if ((c.type === 'select' || c.type === 'multiselect') && c.field && !c.options) {
    const vals = distinct(c.field).sort();
    c.options = vals.map((v) => ({ value: v, label: c.labels?.[v] ?? v }));
    if (c.type === 'multiselect') {
      const def = Array.isArray(c.default) ? c.default.filter((v) => vals.includes(v)) : [];
      c.default = def.length ? def : vals; // runtime narrows to the active scope
    } else if (c.default === '@latest') c.default = vals[vals.length - 1];
    else if (typeof c.default === 'string' && !vals.includes(c.default)) c.default = vals[0];
  }
}
---

<BaseLayout title={`${spec.title} — TSOI`} description={spec.description} og_image={`/og/dashboards/${slug}.png`} noindex>
  <Masthead />
  <SectionNav />
  <main class="tsoi-container dash-page">
    <a class="back" href="/economy/dashboards">&lsaquo; All dashboards</a>
    <header class="dash-head">
      <h1>{spec.title}</h1>
      <p class="deck">{spec.description}</p>
      <ShareButtons title={spec.title} />
    </header>
    <DashboardView spec={spec} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .dash-page { padding-block: calc(var(--tsoi-spacing-unit) * 3); }
  .back { display: inline-flex; align-items: center; gap: 5px; font: var(--tsoi-text-byline); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--tsoi-color-primary); text-decoration: none; padding: 4px 0; margin-bottom: calc(var(--tsoi-spacing-unit) * 2); }
  .back:hover { text-decoration: underline; }
  .dash-head { max-width: 70ch; margin-bottom: calc(var(--tsoi-spacing-unit) * 3); }
  .dash-head h1 { margin: 0; font: var(--tsoi-text-headline-lg); letter-spacing: var(--tsoi-text-headline-lg-tracking); }
  .deck { margin: var(--tsoi-spacing-unit) 0 0; font: var(--tsoi-text-deck); color: var(--tsoi-color-on-surface-variant); }
</style>
