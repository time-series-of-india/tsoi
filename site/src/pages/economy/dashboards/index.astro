---
// Dashboard list view for the Economy theme. Every dashboard sits in ONE uniform
// thumbnail grid — no flagship banner (the dashboards are peers, not ranked).
// Thumbnails are real desktop screenshots of each dashboard's top region — the
// control bar, stat strip and first chart row (public/thumbs/dashboards/<slug>.png
// + -dark.png), generated by scripts/build-dashboard-thumbs.mjs. The 16/9 card
// crops from the top-left. The shared Beats ⇄ Reads ⇄ Dashboards toggle keeps the
// three list views in lockstep.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Masthead from '../../../components/layout/Masthead.astro';
import SectionNav from '../../../components/layout/SectionNav.astro';
import Footer from '../../../components/layout/Footer.astro';
import ViewToggle from '../../../components/editorial/ViewToggle.astro';
import { dashboardsByTheme } from '../../../lib/dashboards/specs';

const dashboards = dashboardsByTheme('economy');
const thumb = (slug: string) => `/thumbs/dashboards/${slug}.png`;
const thumbDark = (slug: string) => `/thumbs/dashboards/${slug}-dark.png`;
---

<BaseLayout
  title="Economy Dashboards — TSOI"
  description="Interactive, spec-driven dashboards of India's payment systems — built from official RBI and NPCI data."
  noindex
>
  <Masthead />
  <SectionNav />
  <main class="tsoi-container list-page">
    <ViewToggle active="dashboards" />

    <header class="list-head">
      <p class="kicker">Economy</p>
      <h1>Dashboards</h1>
      <p class="deck">
        Interactive views of India's payment systems. Each is built from a small spec over official
        RBI / NPCI data &mdash; pick the instruments, window and aggregation, and the charts follow.
      </p>
    </header>

    <!-- ── all dashboards, one uniform grid ────────────────────────────── -->
    <div class="dash-grid">
      {dashboards.map((d) => (
        <a class="card" href={`/economy/dashboards/${d.slug}`}>
          <span class="card-cover">
            <img class="t-light" src={thumb(d.slug)} alt="" loading="lazy" />
            <img class="t-dark" src={thumbDark(d.slug)} alt="" loading="lazy" />
          </span>
          <span class="card-body">
            <span class="card-title">{d.title}</span>
            <span class="card-deck">{d.description}</span>
            <span class="go">Open dashboard &rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .list-page { padding-block: calc(var(--tsoi-spacing-unit) * 3); }

  .list-head { max-width: 70ch; margin-bottom: calc(var(--tsoi-spacing-unit) * 3); }
  .kicker { margin: 0 0 var(--tsoi-spacing-unit); font: var(--tsoi-text-byline); letter-spacing: var(--tsoi-text-byline-tracking); text-transform: uppercase; color: var(--tsoi-color-primary); }
  .list-head h1 { margin: 0; font: var(--tsoi-text-headline-lg); letter-spacing: var(--tsoi-text-headline-lg-tracking); }
  .list-head .deck { margin: var(--tsoi-spacing-unit) 0 0; font: var(--tsoi-text-deck); color: var(--tsoi-color-on-surface-variant); }

  /* ── dashboard grid ─────────────────────────────────────────────────── */
  .dash-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: calc(var(--tsoi-spacing-unit) * 4) calc(var(--tsoi-spacing-unit) * 3); margin-top: calc(var(--tsoi-spacing-unit) * 2); }
  .card { display: block; text-decoration: none; color: inherit; }
  .card-cover {
    display: block; aspect-ratio: 16 / 9; overflow: hidden;
    background: var(--tsoi-color-surface-container-low);
    border: 1px solid var(--tsoi-color-outline);
    transition: border-color 0.15s;
  }
  .card:hover .card-cover { border-color: var(--tsoi-color-primary); }
  .card-cover img { width: 100%; height: 100%; object-fit: cover; object-position: top left; display: block; }
  /* theme-swapped captures: light by default, dark under [data-theme='dark'] */
  .card-cover .t-dark { display: none; }
  :global(html[data-theme='dark']) .card-cover .t-light { display: none; }
  :global(html[data-theme='dark']) .card-cover .t-dark { display: block; }
  .card-body { display: block; padding-top: calc(var(--tsoi-spacing-unit) * 1.5); }
  .card-title { display: block; font: var(--tsoi-text-headline-md); letter-spacing: var(--tsoi-text-headline-md-tracking); line-height: 1.2; }
  .card:hover .card-title { color: var(--tsoi-color-primary); }
  .card-deck {
    display: block; margin: var(--tsoi-spacing-unit) 0 0;
    font: var(--tsoi-text-body); letter-spacing: var(--tsoi-text-body-tracking);
    color: var(--tsoi-color-on-surface-variant);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .go { display: block; margin-top: calc(var(--tsoi-spacing-unit) * 1.25); font: var(--tsoi-text-byline); text-transform: uppercase; letter-spacing: 0.06em; color: var(--tsoi-color-primary); }

  /* ── responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .dash-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    /* grid → single column, motif beside title (compact list feel) */
    .dash-grid { grid-template-columns: 1fr; gap: 0; }
    .card {
      display: grid; grid-template-columns: 132px 1fr;
      column-gap: calc(var(--tsoi-spacing-unit) * 2);
      align-items: center;
      padding: calc(var(--tsoi-spacing-unit) * 2) 0;
    }
    .card + .card { border-top: var(--tsoi-rule-column) solid var(--tsoi-color-outline); }
    .card-body { padding-top: 0; }
    .card-deck { display: none; }
    .go { margin-top: var(--tsoi-spacing-unit); }
  }
</style>
