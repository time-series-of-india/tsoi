---
// All payments desks on one page. Folds the six standalone dashboards
// (/economy/explore/{slug}) into sticky-bar "desks" so a reader can work
// through every angle on India's payment systems without leaving the page.
// Canonical: this is the URL search (and /economy/explore) should send
// readers to for India payments; the standalone per-board pages are being
// retired in favour of it.
//
// NOTE on URL: the brief that shaped this page referred to a
// site/src/pages/economy/dashboards/all.astro path from before the Jul 2026
// beats/reads/dashboards → play/read/explore rename (astro.config.mjs now
// redirects the whole /economy/dashboards/* namespace to /economy/explore/*,
// including the dynamic [slug] pattern — a literal page at
// economy/dashboards/all would collide with that redirect). This page lives
// at economy/explore/payments: subject-named, since future dashboards (food prices, ...) will land beside it.
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { resolve as pathResolve, dirname } from 'node:path';
import StoryPage from '../../../layouts/StoryPage.astro';
import DesksView from '../../../components/dashboard/DesksView.astro';
import type { DeskDef } from '../../../components/dashboard/DesksView.astro';
import { DASHBOARDS } from '../../../lib/dashboards/specs';

const PUBLIC = pathResolve(dirname(fileURLToPath(import.meta.url)), '../../../../public');

// Build-time enrichment: fill
// select/multiselect options (and resolve '@latest' defaults) from each
// dashboard's own tidy dataset, so the static markup never shows an empty
// control while the client fetch is in flight — worth doing here even more
// than on the standalone pages, since a lower desk's fetch may not start
// until the reader scrolls near it.
function enrich(spec: (typeof DASHBOARDS)[number]) {
  const clone = structuredClone(spec);
  const { rows } = JSON.parse(readFileSync(pathResolve(PUBLIC, '.' + clone.dataset), 'utf8'));
  for (const c of clone.globals ?? []) {
    if ((c.type === 'select' || c.type === 'multiselect') && c.field && !c.options) {
      // Mirror the runtime's scopedRows/populateMulti semantics: honor the
      // control's constant `where` scope (else e.g. PSP names bake into an
      // apps control) and its `defaultTop` (else an empty default bakes in as
      // "everything selected" and the runtime never applies the top-N).
      const scoped = c.where
        ? rows.filter((r: any) => Object.entries(c.where!).every(([f, v]) => String(r[f]) === v))
        : rows;
      const vals: string[] =
        [...new Set<string>(scoped.filter((r: any) => r[c.field!] != null).map((r: any) => String(r[c.field!])))].sort();
      c.options = vals.map((v) => ({ value: v, label: c.labels?.[v] ?? v }));
      if (c.type === 'multiselect') {
        const def = Array.isArray(c.default) ? c.default.filter((v) => vals.includes(v)) : [];
        if (def.length) c.default = def;
        else if (c.defaultTop) {
          const by = c.rankBy ?? 'volume_cr';
          const tot: Record<string, number> = {};
          for (const r of scoped) { const k = String(r[c.field!]); tot[k] = (tot[k] ?? 0) + (Number(r[by]) || 0); }
          c.default = vals.slice().sort((a, b) => (tot[b] ?? 0) - (tot[a] ?? 0)).slice(0, c.defaultTop);
        } else c.default = vals;
      } else if (c.default === '@latest') c.default = vals[vals.length - 1];
      else if (typeof c.default === 'string' && !vals.includes(c.default)) c.default = vals[0];
    }
  }
  return clone;
}

// Desk order matches the standalone dashboards index (economy/explore/index.astro):
// overview first, then its facets in the order they're listed there.
const DESK_META: Record<string, { anchor: string; title: string; info: string }> = {
  overview: {
    anchor: 'overview',
    title: 'Overview',
    info: 'The headline totals and instrument mix at a glance: pick instruments, a time window and an aggregation to compare volume, value and market share side by side.',
  },
  'product-view': {
    anchor: 'product',
    title: 'Product explorer',
    info: 'Drill into one payment instrument at a time by category, operator and product, tracking its volume, value, average daily activity and ticket size.',
  },
  'bank-performance': {
    anchor: 'banks',
    title: 'Bank performance',
    info: 'How individual banks perform on UPI and IMPS, comparing transaction volume and decline rates with a live ranking of the busiest banks.',
  },
  'upi-ecosystem': {
    anchor: 'apps',
    title: 'Apps & PSPs',
    info: 'Which consumer apps and PSP banks move UPI payments, by transaction volume and value over a chosen time window.',
  },
  'state-wise': {
    anchor: 'states',
    title: 'State-wise',
    info: 'UPI activity across India’s states and union territories for a chosen month, ranked from busiest to quietest.',
  },
  mcc: {
    anchor: 'mcc',
    title: 'Merchant categories',
    info: 'What Indians buy on UPI, broken down by merchant category such as groceries, fuel stations and fast food.',
  },
};

const ORDER = ['overview', 'product-view', 'bank-performance', 'upi-ecosystem', 'mcc', 'state-wise'];
const desks: DeskDef[] = ORDER.map((slug) => {
  const spec = DASHBOARDS.find((d) => d.slug === slug)!;
  const meta = DESK_META[slug];
  return { spec: enrich(spec), anchor: meta.anchor, title: meta.title, info: meta.info };
});
---

<StoryPage
  title="India Payments — All Desks — TSOI"
  description="Every India payments desk on one page: overview, product explorer, bank performance, apps and PSPs, merchant categories and state-wise, built from official RBI and NPCI data."
  og_image="/og/dashboards/all.png"
  wide
>
  <!-- folio, not a back button: states where the board lives ("Economy ·
       Explore"), matching the Read and Play pages. The masthead is the only
       road home; the browser owns history. -->
  <nav class="folio" aria-label="Section">
    <a href="/economy">Economy</a><span class="dot" aria-hidden="true">&middot;</span><a href="/economy/explore">Explore</a>
  </nav>
  <header class="all-head">
    <h1>India Payments</h1>
    <p class="deck">
      Every payments desk on one page. Each desk below covers one angle of India's payment
      systems, from the headline totals to bank performance, apps, merchant categories and
      states. Data comes from RBI and NPCI monthly releases. Drag across any chart to zoom
      every desk to the same window.
    </p>
  </header>

  <nav class="jump" aria-label="Desks on this page">
    {desks.map((d) => <a href={`#${d.anchor}`}>{d.title}</a>)}
  </nav>

  <DesksView desks={desks} />
</StoryPage>

<script>
  // Smooth-scroll the jump nav instead of the browser's instant hash jump —
  // same destination (scroll-margin-top on .desk keeps the sticky bar clear
  // of the desk title), just an eased scroll. Still updates the URL hash via
  // pushState, so the links stay shareable/bookmarkable.
  //
  // Now that desks can restore COLLAPSED (see DesksView.astro's collapse
  // state machine), a hash landing on a folded desk needs to force it open
  // before scrolling — expanding changes the document's height, so scrolling
  // first would land short. DesksView exposes expandAndScrollTo on
  // window.tsoiDesks for exactly this: it's a separate inline script (own
  // module scope), rendered earlier in this page's markup, so by the time
  // this script runs the bridge is guaranteed to already exist (module
  // scripts execute in document order, same as defer).
  //
  // Four entry points need the same "force-expand, then scroll" treatment:
  // a jump-nav click, the page's OWN initial hash on load (previously
  // handled by nothing — the browser's native jump did the work, which now
  // lands at the wrong offset once a desk can restore folded), hashchange
  // (a hash typed/pasted into the address bar while already on the page),
  // and popstate (Back/Forward traversal).
  function goToAnchor(id: string, smooth: boolean) {
    if (!document.getElementById(id)) return;
    window.tsoiDesks?.expandAndScrollTo(id, { smooth });
  }
  // Tracks the hash we've already acted on — see onHashNav below for why.
  let lastAnchorHash = location.hash;

  document.querySelectorAll<HTMLAnchorElement>('.jump a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const id = a.getAttribute('href')!.slice(1);
      if (!document.getElementById(id)) return;
      e.preventDefault();
      history.pushState(null, '', `#${id}`);
      lastAnchorHash = location.hash;
      goToAnchor(id, true);
    });
  });

  // Initial load with a hash (e.g. /economy/explore/payments#banks): applied
  // instantly (not smoothly) since this is first paint settling, not a user
  // gesture reacting to something already on screen.
  if (location.hash) goToAnchor(location.hash.slice(1), false);

  // hashchange (address-bar hash edits) and popstate (Back/Forward) both
  // need the same reaction, but must ignore firings where the hash didn't
  // actually change — panel-chrome.ts's shared overlay stack (maximize)
  // pushes its OWN history entries with an unchanged URL/hash (see
  // pushOverlay's empty second history.pushState argument), so closing a
  // maximized desk/panel via Back also fires 'popstate' here. Comparing
  // against the hash we last acted on (rather than inspecting that other
  // handler's private state shape) is what keeps the two from fighting:
  // an overlay-close popstate leaves location.hash untouched, so it's a
  // no-op below, while a real anchor navigation always changes it.
  function onHashNav() {
    if (location.hash === lastAnchorHash) return;
    lastAnchorHash = location.hash;
    if (location.hash) goToAnchor(location.hash.slice(1), true);
  }
  window.addEventListener('hashchange', onHashNav);
  window.addEventListener('popstate', onHashNav);
</script>

<style>
  /* folio — matches ReadLayout / OffByHowMuch so all three formats state
     where they live in the same voice */
  .folio { font: var(--tsoi-text-byline); font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; padding: 4px 0; margin-bottom: calc(var(--tsoi-spacing-unit) * 2); }
  .folio a { color: var(--tsoi-color-primary-text); text-decoration: none; }
  .folio a:hover { text-decoration: underline; }
  .folio .dot { color: var(--tsoi-color-on-surface-variant); padding-inline: 5px; }

  .all-head { max-width: 70ch; }
  .all-head h1 { margin: 0; font: var(--tsoi-text-headline-lg); letter-spacing: var(--tsoi-text-headline-lg-tracking); }
  .deck { margin: var(--tsoi-spacing-unit) 0 0; font: var(--tsoi-text-deck); color: var(--tsoi-color-on-surface-variant); }

  .jump {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: var(--tsoi-spacing-unit) calc(var(--tsoi-spacing-unit) * 2.5);
    margin-top: calc(var(--tsoi-spacing-unit) * 2);
    padding-bottom: calc(var(--tsoi-spacing-unit) * 1.5);
    border-bottom: var(--tsoi-rule-column) solid var(--tsoi-color-outline);
    font: var(--tsoi-text-byline); font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .jump a { color: var(--tsoi-color-primary-text); text-decoration: none; }
  .jump a:hover { text-decoration: underline; }
</style>
