  .flowfig :global(.inode .k) { font: var(--tsoi-text-headline-sm); font-size: calc(14px * var(--dgm-scale)); color: var(--ent); white-space: nowrap; }
  .flowfig :global(.inode .s) { font: var(--tsoi-text-byline); font-size: calc(11.5px * var(--dgm-scale)); color: var(--tsoi-color-on-surface-variant); white-space: nowrap; }
