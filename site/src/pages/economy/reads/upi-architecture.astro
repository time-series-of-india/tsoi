  .statfig .bigstat { display: flex; flex-direction: column; gap: 4px; padding: calc(var(--tsoi-spacing-unit) * 2.5); border-left: 4px solid var(--tsoi-color-primary); background: var(--tsoi-color-surface-container-low); }
