---
// "Coming soon" landing for the not-yet-live theme sections (linked from the
// section nav). Deliberately wordless: the section header, a dotted placeholder
// time-series, and a small "coming soon" caption — no descriptive copy.
// Static paths for the four planned themes only; static routes like /about,
// /data, /economy take precedence over this dynamic route.
// Note: getStaticPaths runs before the frontmatter body, so the theme data is
// defined inside it and passed through props (blurb is meta-description only).
import StoryPage from '../layouts/StoryPage.astro';
import SectionHeader from '../components/editorial/SectionHeader.astro';

export function getStaticPaths() {
  const THEMES = {
    environment: {
      label: 'Environment',
      blurb: 'Air quality, emissions, forest cover, rainfall and water — India’s environment, charted from official monitoring and ministry releases. Coming soon.',
    },
    infrastructure: {
      label: 'Infrastructure',
      blurb: 'Power, roads, railways, ports and telecom — the build-out of India, in the numbers the state itself publishes. Coming soon.',
    },
    demographics: {
      label: 'Demographics',
      blurb: 'Population, the census, migration and urbanisation — who India is and how that is changing, over time. Coming soon.',
    },
    governance: {
      label: 'Governance',
      blurb: 'Budgets, public schemes, elections and service delivery — how the state spends and performs, made legible. Coming soon.',
    },
  };
  return Object.entries(THEMES).map(([theme, data]) => ({ params: { theme }, props: data }));
}

const { label, blurb } = Astro.props;
---

<StoryPage title={`${label} — Time Series of India`} description={blurb}>
  <SectionHeader label={label} />
  <div class="soon">
    <svg class="placeholder" viewBox="0 0 600 240" role="img" aria-label={`${label} — coming soon`}>
      <!-- axes -->
      <line class="axis" x1="24" y1="16" x2="24" y2="208" />
      <line class="axis" x1="24" y1="208" x2="584" y2="208" />
      <!-- dashed gridlines -->
      <line class="grid" x1="24" y1="64" x2="584" y2="64" />
      <line class="grid" x1="24" y1="112" x2="584" y2="112" />
      <line class="grid" x1="24" y1="160" x2="584" y2="160" />
      <!-- dotted placeholder series -->
      <polyline
        class="series"
        points="24,184 94,170 164,178 234,142 304,150 374,108 444,120 514,74 584,52"
      />
    </svg>
    <p class="cap">Coming soon</p>
  </div>
</StoryPage>

<style>
  .soon {
    max-width: 640px;
    margin: calc(var(--tsoi-spacing-unit) * 5) auto;
    text-align: center;
  }
  .placeholder {
    width: 100%;
    height: auto;
    opacity: 0.7;
  }
  .placeholder .axis {
    stroke: var(--tsoi-color-outline);
    stroke-width: 1;
  }
  .placeholder .grid {
    stroke: var(--tsoi-color-outline);
    stroke-width: 1;
    stroke-dasharray: 3 7;
    opacity: 0.6;
  }
  .placeholder .series {
    fill: none;
    stroke: var(--tsoi-color-primary);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1 9;
  }
  .cap {
    margin: calc(var(--tsoi-spacing-unit) * 3) 0 0;
    font: var(--tsoi-text-byline);
    letter-spacing: var(--tsoi-text-byline-tracking);
    text-transform: uppercase;
    color: var(--tsoi-color-on-surface-variant);
  }
</style>
