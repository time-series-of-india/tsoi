---
// Standard editorial page: BaseLayout + masthead/nav/footer chrome, with the
// page content inside the broadsheet grid container.
import BaseLayout from './BaseLayout.astro';
import Masthead from '../components/layout/Masthead.astro';
import SectionNav from '../components/layout/SectionNav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  og_type?: 'website' | 'article';
  og_image?: string;
  noindex?: boolean;
  source_agency?: string;
  source_url?: string;
  last_updated?: string;
  /** Front page only: render the masthead wordmark as the page h1. */
  homeH1?: boolean;
  /** Opt in to the wide container tier (≥1600px) for data-dense dashboard
   * surfaces. Editorial/prose pages should leave this unset — the 1280px
   * measure stays the default. */
  wide?: boolean;
}

const { homeH1 = false, wide = false, ...props } = Astro.props;
---

<BaseLayout {...props}>
  <slot name="ld-json" slot="ld-json" />
  <Masthead homeH1={homeH1} />
  <SectionNav />
  <main class:list={['tsoi-container', 'story-main', { 'tsoi-container-wide': wide }]}>
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style>
  .story-main {
    padding-top: calc(var(--tsoi-spacing-unit) * 3);
    padding-bottom: calc(var(--tsoi-spacing-unit) * 6);
  }
</style>
