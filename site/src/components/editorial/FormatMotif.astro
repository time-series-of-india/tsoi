---
// The format mark — one thin, equal-weight mark per dispatch-item format
// (structure, not skin; never an icon): a read is lines of prose, a deck is a
// row of portrait mini-cards (the object, not the swipe — decks swipe
// vertically, so the old horizontal dashes read as the wrong gesture; cards
// have no direction to be wrong about), a dashboard is a stack of desks —
// three flush bands, each a full-width saffron rule over a shorter muted line
// (the dashboard stopped being one chart when the six boards folded into one
// page of desks, so the old single time-series polyline was describing a page
// that no longer exists; the rule-over-content band is literally what a desk
// looks like on /economy/explore/payments), a game is a gauge — two pins on a
// track, your guess and the actual,
// slightly apart (the reveal mechanic drawn small: "off by how much").
// Same 74×14 slot everywhere; colour follows CSS `color` in context
// (saffron by default, muted where the context sets it). The mark is
// decorative — the format name travels with it for screen readers unless the
// caller already shows it as visible text (`unlabelled`).
import { FORMAT_LABELS, type DispatchFormat } from '../../lib/dispatches';

interface Props {
  format: DispatchFormat;
  /** beat-deck only: the "N cards" kicker meta — one mini-card per card */
  meta?: string;
  /** set when visible text next to the mark already names the format */
  unlabelled?: boolean;
}

const { format, meta, unlabelled = false } = Astro.props;

const cardCount = (() => {
  const n = parseInt(meta ?? '', 10);
  return Number.isFinite(n) && n > 0 && n <= 6 ? n : 5; // 6 × 11px + 7 fits the slot
})();
---

{format === 'read' && (
  <svg class="motif" viewBox="0 0 74 14" width="74" height="14" aria-hidden="true">
    <line x1="1" y1="2.5" x2="73" y2="2.5" stroke-width="1.5" stroke-linecap="round" />
    <line x1="1" y1="7" x2="73" y2="7" stroke-width="1.5" stroke-linecap="round" />
    <line x1="1" y1="11.5" x2="45" y2="11.5" stroke-width="1.5" stroke-linecap="round" />
  </svg>
)}
{format === 'beat-deck' && (
  <svg class="motif" viewBox="0 0 74 14" width="74" height="14" aria-hidden="true">
    {Array.from({ length: cardCount }).map((_, i) => (
      <rect
        class:list={['mini-card', { solid: i === 0 }]}
        x={0.75 + i * 11}
        y="1"
        width="7"
        height="12"
        rx="1"
      />
    ))}
  </svg>
)}
{format === 'dashboard' && (
  <svg class="motif" viewBox="0 0 74 14" width="74" height="14" aria-hidden="true">
    {[1.5, 6, 10.5].map((y) => (
      <>
        <line x1="1" y1={y} x2="73" y2={y} stroke-width="1.5" stroke-linecap="round" />
        <line
          class="desk-body"
          x1="1"
          y1={y + 2.5}
          x2={y === 1.5 ? 30 : y === 6 ? 46 : 38}
          y2={y + 2.5}
          stroke-width="1"
          stroke-linecap="round"
        />
      </>
    ))}
  </svg>
)}
{format === 'game' && (
  <svg class="motif" viewBox="0 0 74 14" width="74" height="14" aria-hidden="true">
    <line x1="1" y1="7" x2="21.5" y2="7" stroke-width="1.5" stroke-linecap="round" />
    <line x1="30.5" y1="7" x2="73" y2="7" stroke-width="1.5" stroke-linecap="round" />
    <circle class="pin-guess" cx="26" cy="7" r="3.25" />
    <circle class="pin-actual" cx="48" cy="7" r="3.25" />
  </svg>
)}
{!unlabelled && <span class="sr-only">{FORMAT_LABELS[format]}</span>}

<style>
  .motif { display: block; color: var(--tsoi-color-primary); }
  .motif rect { fill: currentColor; }
  /* deck mini-cards: outlines, the current (first) one solid */
  .motif .mini-card { fill: none; stroke: currentColor; stroke-width: 1.2; }
  .motif .mini-card.solid { fill: currentColor; stroke: none; }
  .motif polyline, .motif line { stroke: currentColor; }
  /* the desk's content under its bar — muted, so the saffron rules carry the
     stack and the mark still reads at 74px wide */
  .motif .desk-body { stroke: var(--tsoi-color-outline); }
  /* game gauge: the hollow pin is the guess (track breaks under it), the
     solid pin is the actual — same bead-weight as the deck's mini-cards */
  .motif .pin-guess { fill: none; stroke: currentColor; stroke-width: 1.5; }
  .motif .pin-actual { fill: currentColor; stroke: none; }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
</style>
