---
// Cell of the secondary-stories strip: tag, small headline, decorative mini
// chart bars (placeholder until real sparklines arrive with Epic 3 data).
interface Props {
  tag: string;
  title: string;
  href?: string;
  /** Relative bar heights (0–100) for the mini chart placeholder. */
  bars?: number[];
}

const { tag, title, href, bars = [35, 55, 45, 70, 60, 85] } = Astro.props;
---

<div class="strip-item">
  <p class="tag">{tag}</p>
  <h3 class="title">
    {href ? <a href={href}>{title}</a> : title}
  </h3>
  <div class="mini-chart" aria-hidden="true">
    {bars.map((h, i) => <span class:list={['bar', { latest: i === bars.length - 1 }]} style={`height: ${h}%;`} />)}
  </div>
</div>

<style>
  .tag {
    margin: 0 0 calc(var(--tsoi-spacing-unit) / 2);
    font: var(--tsoi-text-label-caps);
    letter-spacing: var(--tsoi-text-label-caps-tracking);
    text-transform: uppercase;
    color: var(--tsoi-color-primary);
  }

  .title {
    margin: 0;
    font: var(--tsoi-text-headline-sm);
    letter-spacing: var(--tsoi-text-headline-sm-tracking);
  }

  .title a {
    display: block;
    text-decoration: none;
    color: var(--tsoi-color-on-surface);
  }

  .title a:hover {
    color: var(--tsoi-color-primary);
  }

  .mini-chart {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 32px;
    margin-top: var(--tsoi-spacing-unit);
  }

  .bar {
    flex: 1;
    max-width: 14px;
    background: var(--tsoi-color-outline);
  }

  /* Current period highlighted in the series colour. */
  .bar.latest {
    background: var(--tsoi-color-chart-1);
  }
</style>
