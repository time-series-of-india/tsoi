---
// Dependency-free share control: a trigger that opens a small popover with a
// single row of monochrome icons — X / LinkedIn / Reddit / WhatsApp / Copy-link,
// plus native navigator.share on mobile. Broadsheet aesthetic — one understated
// control, no third-party widgets, no tracking.
//
// Three shapes:
//   button   — a labelled "Share" button, sits in-flow at the end of content
//              (reads, dashboard header).
//   icon     — an icon-only button, in-flow (the flagship read's top toolbar).
//   fab      — an icon-only button fixed in the top-right chrome (beats deck),
//              deliberately subtle and always reachable.
//
// The <a> hrefs are built at build time from the canonical URL (work with no
// JS), but a tiny enhancement rebuilds the target from the LIVE location.href on
// click — so a shared dashboard link carries its current control state.
interface Props {
  title: string;                     // the headline that travels with the link
  variant?: 'button' | 'icon' | 'fab'; // labelled, icon-only in-flow, or corner fab
  divider?: boolean;                 // top hairline rule (button variant only)
  align?: 'start' | 'center';        // popover anchor edge for the button variant
}
const { title, variant = 'button', divider = true, align = 'start' } = Astro.props;
const iconOnly = variant !== 'button';
const url = new URL(Astro.url.pathname, Astro.site).href;
const t = encodeURIComponent(title);
const u = encodeURIComponent(url);

const SHARE_GLYPH = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="2.6"/><circle cx="6" cy="12" r="2.6"/><circle cx="18" cy="19" r="2.6"/><path d="M8.3 13.3l7.4 4.4M15.7 6.3l-7.4 4.4"/></svg>`;
const ICONS: Record<string, string> = {
  x: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  reddit: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-6.994 4.87-3.865 0-6.994-2.176-6.994-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12c-.689 0-1.25.561-1.25 1.25 0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>`,
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  copy: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
};

const NETS = [
  { net: 'x',        label: 'X',        href: `https://twitter.com/intent/tweet?text=${t}&url=${u}` },
  { net: 'linkedin', label: 'LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}` },
  { net: 'reddit',   label: 'Reddit',   href: `https://www.reddit.com/submit?url=${u}&title=${t}` },
  { net: 'whatsapp', label: 'WhatsApp', href: `https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}` },
];
const isFab = variant === 'fab';
---

<div class="share" class:list={{ divider: divider && variant === 'button', 'is-icon': iconOnly, 'is-fab': isFab }} data-share data-title={title} data-align={isFab ? 'end' : align}>
  <button type="button" class="share-btn" aria-haspopup="true" aria-expanded="false" aria-label="Share">
    <Fragment set:html={SHARE_GLYPH} />
    {!iconOnly && <span>Share</span>}
  </button>
  <div class="share-menu" hidden>
    {NETS.map((n) => (
      <a class="share-ic" data-net={n.net} href={n.href} target="_blank" rel="noopener noreferrer" aria-label={`Share on ${n.label}`} title={n.label}><Fragment set:html={ICONS[n.net]} /></a>
    ))}
    <button type="button" class="share-ic share-native" hidden aria-label="Share via…" title="Share via…"><Fragment set:html={SHARE_GLYPH} /></button>
    <button type="button" class="share-ic share-copy" aria-label="Copy link" title="Copy link"><Fragment set:html={ICONS.copy} /></button>
  </div>
</div>

<style>
  .share { position: relative; display: inline-flex; }
  .share:not(.is-icon) { margin-top: calc(var(--tsoi-spacing-unit) * 3); }
  .share.divider { display: flex; border-top: 1px solid var(--tsoi-color-outline); padding-top: calc(var(--tsoi-spacing-unit) * 2); }
  .share.is-fab { position: fixed; top: 12px; right: 52px; z-index: 10; }

  .share-btn {
    display: inline-flex; align-items: center; gap: 7px; cursor: pointer;
    font: var(--tsoi-text-byline); text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--tsoi-color-on-surface);
    background: var(--tsoi-color-surface); border: 1px solid var(--tsoi-color-outline);
    padding: 5px 11px; border-radius: 2px; transition: color 0.12s, border-color 0.12s;
  }
  .share-btn:hover { color: var(--tsoi-color-primary); border-color: var(--tsoi-color-primary); }
  /* icon-only trigger (top toolbar + beats fab): a compact square, matching the
     deck's theme toggle at 30×30 */
  .share.is-icon .share-btn { width: 30px; height: 30px; padding: 0; justify-content: center; gap: 0; }

  .share-menu {
    position: absolute; z-index: 20; top: calc(100% + 6px);
    display: flex; padding: 5px; gap: 2px;
    background: var(--tsoi-color-surface); border: 1px solid var(--tsoi-color-outline);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }
  .share[data-align='start'] .share-menu { left: 0; }
  .share[data-align='center'] .share-menu { left: 50%; transform: translateX(-50%); }
  .share[data-align='end'] .share-menu { right: 0; }
  .share-menu.up { top: auto; bottom: calc(100% + 6px); }
  /* the explicit display:flex above would otherwise defeat the [hidden] attribute */
  .share-menu[hidden] { display: none; }

  .share-ic {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; padding: 0; border: 0; border-radius: 2px; cursor: pointer;
    background: none; color: var(--tsoi-color-on-surface-variant); transition: color 0.12s, background 0.12s;
  }
  .share-ic :global(svg) { width: 18px; height: 18px; }
  .share-ic:hover { color: var(--tsoi-color-primary); background: var(--tsoi-color-surface-container-high); }
  .share-copy.copied { color: var(--tsoi-color-primary); }
</style>

<script>
  const enc = encodeURIComponent;
  const build = (net: string, url: string, title: string) => {
    switch (net) {
      case 'x':        return `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}`;
      case 'linkedin': return `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`;
      case 'reddit':   return `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}`;
      case 'whatsapp': return `https://wa.me/?text=${enc(title + ' ' + url)}`;
      default:         return url;
    }
  };
  const CHECK = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>`;

  document.querySelectorAll<HTMLElement>('[data-share]').forEach((box) => {
    const title = box.dataset.title ?? document.title;
    const btn = box.querySelector<HTMLButtonElement>('.share-btn')!;
    const menu = box.querySelector<HTMLElement>('.share-menu')!;

    const close = () => { menu.hidden = true; menu.classList.remove('up'); btn.setAttribute('aria-expanded', 'false'); };
    const open = () => {
      menu.hidden = false;
      btn.setAttribute('aria-expanded', 'true');
      const r = menu.getBoundingClientRect();     // flip above if it would spill below
      if (r.bottom > innerHeight - 8) menu.classList.add('up');
    };
    btn.addEventListener('click', (e) => { e.stopPropagation(); menu.hidden ? open() : close(); });
    document.addEventListener('click', (e) => { if (!box.contains(e.target as Node)) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

    // Rebuild intent links from the live URL on click (captures dashboard state).
    box.querySelectorAll<HTMLAnchorElement>('a[data-net]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        window.open(build(a.dataset.net!, location.href, title), '_blank', 'noopener,noreferrer,width=600,height=540');
        close();
      });
    });

    const copy = box.querySelector<HTMLButtonElement>('.share-copy')!;
    const copyHtml = copy.innerHTML;
    copy.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(location.href);
        copy.innerHTML = CHECK;
        copy.classList.add('copied');
        copy.setAttribute('aria-label', 'Copied');
        setTimeout(() => { copy.innerHTML = copyHtml; copy.classList.remove('copied'); copy.setAttribute('aria-label', 'Copy link'); }, 1600);
      } catch { /* clipboard blocked — the network links still work */ }
    });

    // Native share sheet: reveal only where supported (mostly mobile).
    const native = box.querySelector<HTMLButtonElement>('.share-native');
    if (native && typeof navigator.share === 'function') {
      native.hidden = false;
      native.addEventListener('click', () => { navigator.share({ title, url: location.href }).catch(() => {}); close(); });
    }
  });
</script>
