---
// The Play ⇄ Read ⇄ Explore switch shared by the Economy list views — the
// three format tabs, all verbs. Single source so the three surfaces stay in
// lockstep. Rides the SectionHeader row itself, folded into the section rule
// via its `actions` slot, right-aligned against the label/hairline/date on
// desktop. Stays a horizontal segmented control at every width (equal-width
// segments on phones, dropping to its own full-width line rather than
// collapsing into three stacked bars).
interface Props { active: 'play' | 'read' | 'explore' }
const { active } = Astro.props;
const items = [
  { key: 'play', label: 'Play', href: '/economy/play' },
  { key: 'read', label: 'Read', href: '/economy/read' },
  { key: 'explore', label: 'Explore', href: '/economy/explore' },
] as const;
---

<div class="view-toggle" role="group" aria-label="View">
  {items.map((it) => (
    <a
      href={it.href}
      class:list={['vt', { active: active === it.key }]}
      aria-current={active === it.key ? 'page' : undefined}
    >
      {it.label}
    </a>
  ))}
</div>

<style>
  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--tsoi-color-outline);
    border-radius: 2px;
    overflow: hidden;
  }
  .vt {
    font: var(--tsoi-text-byline);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 7px 16px;
    text-decoration: none;
    white-space: nowrap;
    background: var(--tsoi-color-background);
    color: var(--tsoi-color-on-surface-variant);
    transition: background 0.15s, color 0.15s;
  }
  .vt + .vt { border-left: 1px solid var(--tsoi-color-outline); }
  .vt:hover:not(.active) { color: var(--tsoi-color-on-surface); background: var(--tsoi-color-surface-container-high); }
  /* Accepted AA deviation (2026-07-19): white on light's #CC5500 fill is
     4.31:1 against the 4.5:1 floor; the passing darker saffron read too red,
     so the brand fill stays. */
  .vt.active { background: var(--tsoi-color-primary); color: #fff; }

  @media (max-width: 600px) {
    /* full-width segmented bar, not a stack — keeps the switch one tap-row tall */
    .view-toggle { display: flex; width: 100%; }
    .vt { flex: 1; text-align: center; padding: 10px 8px; }
  }
</style>
