# build output
dist/
# generated types
.astro/

# build-time data artifacts — regenerated by scripts/rebuild.sh on every deploy;
# committing them would go stale and trip the prebuild freshness gate.
src/data/stats.json
public/og/
# spec-driven dashboard datasets (build-dashboard-data.mjs)
public/data/economy/
# local-only play-stats fixture (scripts/dev-play-stats.mjs) — in production
# this route belongs to the play-score worker, and a shipped static file would
# shadow the real histogram with invented numbers.
public/api/play-stats/

